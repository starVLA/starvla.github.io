---
import BaseLayout from '../layouts/BaseLayout.astro';
import BiText from '../components/BiText.astro';
import { landingContent } from '../data/landingContent';

const featureIconMap: Record<string, string> = {
  puzzle: 'ti ti-puzzle',
  chart: 'ti ti-chart-bar',
  server: 'ti ti-server',
};
---

<BaseLayout title={landingContent.meta.title} description={landingContent.meta.description}>
  <section id="overview" class="section section--compact reveal">
    <div class="container hero hero--single">
      <div>
        <div class="hero-badge">
          <BiText en={landingContent.hero.badge.en} zh={landingContent.hero.badge.zh} />
        </div>
        <h1 class="hero-title">
          <span class="hero-highlight">starVLA</span>
          <br />
          <BiText en={landingContent.hero.title.en} zh={landingContent.hero.title.zh} />
        </h1>
        <p class="hero-subtitle">
          <BiText en={landingContent.hero.subtitle.en} zh={landingContent.hero.subtitle.zh} />
        </p>
        <div class="hero-cta-group">
          <a class="cta cta--primary" href={landingContent.hero.primaryCta.href} target="_blank" rel="noopener noreferrer">
            <BiText en={landingContent.hero.primaryCta.en} zh={landingContent.hero.primaryCta.zh} />
          </a>
          <a class="cta cta--secondary" href={landingContent.hero.secondaryCta.href} target="_blank" rel="noopener noreferrer">
            <BiText en={landingContent.hero.secondaryCta.en} zh={landingContent.hero.secondaryCta.zh} />
          </a>
          <a class="cta cta--secondary" href={landingContent.hero.tertiaryCta.href} target="_blank" rel="noopener noreferrer">
            <BiText en={landingContent.hero.tertiaryCta.en} zh={landingContent.hero.tertiaryCta.zh} />
          </a>
        </div>

        <div class="metrics-grid">
          {
            landingContent.metrics.map((metric) => (
              <a
                class="metric-card"
                href={metric.href}
                target="_blank"
                rel="noopener noreferrer"
                data-badge-url={metric.badgeUrl}
              >
                <span class="metric-label">
                  <BiText en={metric.label.en} zh={metric.label.zh} />
                </span>
                <strong class="metric-value" data-metric-value data-fallback={metric.fallback}>
                  {metric.fallback}
                </strong>
              </a>
            ))
          }
        </div>
      </div>
    </div>
  </section>

  <section class="section reveal">
    <div class="container">
      <h2 class="section-title">
        <BiText en="Design for fast iteration" zh="为快速迭代而设计" />
      </h2>
      <p class="section-lead">
        <BiText
          en="From setup to benchmarking and deployment, the workflow is organized for fast, reliable team iteration."
          zh="从环境搭建到基准评测再到部署落地，整体流程围绕团队快速且可靠的迭代而设计。"
        />
      </p>

      <div class="feature-grid">
        {
          landingContent.features.map((feature) => (
            <article class="card">
              <div class="feature-icon" aria-hidden="true">
                <i class={featureIconMap[feature.icon] ?? 'ti ti-circle'}></i>
              </div>
              <h3>
                <BiText en={feature.enTitle} zh={feature.zhTitle} />
              </h3>
              <p>
                <BiText en={feature.enBody} zh={feature.zhBody} />
              </p>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section id="quick-start" class="section reveal">
    <div class="container quick-start">
      <h2 class="section-title">
        <BiText en={landingContent.quickStart.title.en} zh={landingContent.quickStart.title.zh} />
      </h2>
      <p class="section-lead">
        <BiText en={landingContent.quickStart.intro.en} zh={landingContent.quickStart.intro.zh} />
      </p>

      <div class="quick-controls" id="goalControls">
        {
          landingContent.quickStart.goals.map((goal, idx) => (
            <button class={`pill ${idx === 0 ? 'is-active' : ''}`} type="button" data-goal={goal.key}>
              <BiText en={goal.en} zh={goal.zh} />
            </button>
          ))
        }
      </div>

      <div class="quick-controls" id="benchmarkControls" hidden>
        {
          landingContent.quickStart.benchmarks.map((benchmark, idx) => (
            <button class={`pill ${idx === 0 ? 'is-active' : ''}`} type="button" data-benchmark={benchmark.key}>
              <BiText en={benchmark.en} zh={benchmark.zh} />
            </button>
          ))
        }
      </div>

      <div class="quick-command-grid">
        <article class="code-card">
          <header class="code-head">
            <span id="terminalATitle">Terminal A</span>
            <button class="copy-btn" type="button" data-copy-target="commandA">
              <BiText en="Copy" zh="复制" />
            </button>
          </header>
          <pre class="code-block" id="commandA"></pre>
        </article>

        <article class="code-card" id="terminalBCard">
          <header class="code-head">
            <span id="terminalBTitle">Terminal B</span>
            <button class="copy-btn" type="button" data-copy-target="commandB">
              <BiText en="Copy" zh="复制" />
            </button>
          </header>
          <pre class="code-block" id="commandB"></pre>
        </article>
      </div>

      <p class="quick-note" id="quickNote"></p>
    </div>
  </section>

  <section id="benchmarks" class="section reveal">
    <div class="container">
      <h2 class="section-title">
        <BiText en="Reported benchmark snapshots" zh="已公开基准快照" />
      </h2>
      <p class="section-lead">
        <BiText
          en="Numbers below are reported results from the official StarVLA docs and repository, with source links for verification."
          zh="以下数字来自 StarVLA 官方文档与仓库公开结果，并附带来源链接供核对。"
        />
      </p>

      <div class="benchmark-video-grid">
        {
          landingContent.benchmarkVideos.map((card) => (
            <article class="video-card">
              <div class="video-carousel" aria-label={`${card.enTitle} simulation demos – ${card.metricEn}: ${card.value}`}>
                {card.videos.map((src, i) => (
                  <video
                    class={`video-card__media ${i === 0 ? 'is-active' : ''}`}
                    autoplay={i === 0}
                    muted
                    loop
                    playsinline
                    preload="metadata"
                  >
                    <source src={src} type="video/mp4" />
                  </video>
                ))}
                <div class="video-carousel__dots">
                  {card.videos.map((_, i) => (
                    <button
                      class={`video-carousel__dot ${i === 0 ? 'is-active' : ''}`}
                      type="button"
                      aria-label={`Video ${i + 1}`}
                      data-index={i}
                    />
                  ))}
                </div>
              </div>
              <div class="video-card__body">
                <h3 class="link-card__title">
                  <BiText en={card.enTitle} zh={card.zhTitle} />
                </h3>
                <div class="metric-pill">
                  <BiText en={card.metricEn} zh={card.metricZh} />
                </div>
                <div class="value-line">{card.value}</div>
                <a class="link-row" href={card.source} target="_blank" rel="noopener noreferrer">
                  <BiText en="View benchmark source" zh="查看基准来源" />
                  <span aria-hidden="true">↗</span>
                </a>
              </div>
            </article>
          ))
        }
      </div>

      <div class="benchmark-info-grid">
        <article class="card">
          <h3 class="link-card__title">
            <BiText
              en={landingContent.benchmarkInfo.libero.enTitle}
              zh={landingContent.benchmarkInfo.libero.zhTitle}
            />
          </h3>
          <div class="metric-pill mt-card">
            <BiText
              en={landingContent.benchmarkInfo.libero.metricEn}
              zh={landingContent.benchmarkInfo.libero.metricZh}
            />
          </div>
          <div class="value-line">{landingContent.benchmarkInfo.libero.value}</div>
          <a class="link-row" href={landingContent.benchmarkInfo.libero.source} target="_blank" rel="noopener noreferrer">
            <BiText en="View benchmark docs" zh="查看基准文档" />
            <span aria-hidden="true">↗</span>
          </a>
        </article>

        <article class="card">
          <h3 class="link-card__title">
            <BiText
              en={landingContent.benchmarkInfo.behavior.enTitle}
              zh={landingContent.benchmarkInfo.behavior.zhTitle}
            />
          </h3>
          <div class="metric-pill mt-card">
            <BiText
              en={landingContent.benchmarkInfo.behavior.metricEn}
              zh={landingContent.benchmarkInfo.behavior.metricZh}
            />
          </div>
          <div class="value-line">
            <BiText
              en={landingContent.benchmarkInfo.behavior.valueEn}
              zh={landingContent.benchmarkInfo.behavior.valueZh}
            />
          </div>
          <a class="link-row" href={landingContent.benchmarkInfo.behavior.source} target="_blank" rel="noopener noreferrer">
            <BiText en="Open documentation" zh="打开文档链接" />
            <span aria-hidden="true">↗</span>
          </a>
        </article>
      </div>

      <article class="card benchmark-compare">
        <h3 class="link-card__title">
          <BiText
            en={landingContent.benchmarkComparison.title.en}
            zh={landingContent.benchmarkComparison.title.zh}
          />
        </h3>
        <p class="benchmark-compare__note">
          <BiText
            en={landingContent.benchmarkComparison.note.en}
            zh={landingContent.benchmarkComparison.note.zh}
          />
        </p>
        <table class="benchmark-compare__table" role="table" aria-label="Benchmark comparison values">
          <thead role="rowgroup">
            <tr class="benchmark-compare__row benchmark-compare__row--head" role="row">
              <th role="columnheader">
                <BiText en="Benchmark" zh="基准" />
              </th>
              <th role="columnheader">
                <BiText
                  en={landingContent.benchmarkComparison.currentLabel.en}
                  zh={landingContent.benchmarkComparison.currentLabel.zh}
                />
              </th>
              <th role="columnheader">
                <BiText
                  en={landingContent.benchmarkComparison.previousLabel.en}
                  zh={landingContent.benchmarkComparison.previousLabel.zh}
                />
              </th>
            </tr>
          </thead>
          <tbody role="rowgroup">
            {
              landingContent.benchmarkComparison.rows.map((item) => (
                <tr class="benchmark-compare__row" role="row">
                  <td role="cell">{item.benchmark}</td>
                  <td role="cell" class="benchmark-compare__current">{item.value}</td>
                  <td role="cell">{item.previous}</td>
                </tr>
              ))
            }
          </tbody>
        </table>
      </article>
    </div>
  </section>

  <section id="model-zoo" class="section reveal">
    <div class="container">
      <h2 class="section-title">
        <BiText en="Model Zoo highlights" zh="模型库精选" />
      </h2>
      <p class="section-lead">
        <BiText
          en="Use published backbones and checkpoints to reproduce or extend StarVLA experiments quickly."
          zh="使用已发布骨干和检查点，快速复现或扩展 StarVLA 实验。"
        />
      </p>

      <div class="model-grid">
        {
          landingContent.modelZoo.map((model) => (
            <a class="link-card" href={model.link} target="_blank" rel="noopener noreferrer">
              <h3 class="link-card__title">{model.name}</h3>
              <p class="link-card__desc">
                <BiText en={model.enDesc} zh={model.zhDesc} />
              </p>
            </a>
          ))
        }
      </div>
    </div>
  </section>

  <section id="community" class="section reveal">
    <div class="container">
      <h2 class="section-title">
        <BiText en="Community and resources" zh="社区与资源" />
      </h2>
      <p class="section-lead">
        <BiText
          en="Get help, follow live progress, and collaborate with researchers and engineers in the StarVLA ecosystem."
          zh="获取支持、跟进实时进展，并与 StarVLA 生态中的研究者和工程师协作。"
        />
      </p>

      <div class="community-grid">
        <a class="link-card" href={landingContent.community.docs} target="_blank" rel="noopener noreferrer">
          <h3 class="link-card__title">Docs</h3>
          <p class="link-card__desc">
            <BiText en="Official setup, benchmarks, and training guides." zh="官方安装、评测与训练指南。" />
          </p>
        </a>
        <a class="link-card" href={landingContent.community.github} target="_blank" rel="noopener noreferrer">
          <h3 class="link-card__title">GitHub</h3>
          <p class="link-card__desc">
            <BiText en="Source code, issues, pull requests, and updates." zh="源码、issue、PR 与最新更新。" />
          </p>
        </a>
        <a class="link-card" href={landingContent.community.huggingFace} target="_blank" rel="noopener noreferrer">
          <h3 class="link-card__title">Hugging Face</h3>
          <p class="link-card__desc">
            <BiText en="Published models, checkpoints, and datasets." zh="已发布模型、检查点与数据集。" />
          </p>
        </a>
        <a class="link-card" href={landingContent.community.wechatIssue} target="_blank" rel="noopener noreferrer">
          <h3 class="link-card__title">WeChat</h3>
          <p class="link-card__desc">
            <BiText en="Join via issue thread link." zh="通过 issue 链接加入中文交流群。" />
          </p>
        </a>
      </div>

      <div class="resource-grid">
        <a class="link-card" href={landingContent.community.overleaf} target="_blank" rel="noopener noreferrer">
          <h3 class="link-card__title">
            <BiText en="Live Report" zh="实时报告" />
          </h3>
          <p class="link-card__desc">
            <BiText en="Continuously updated experiment report and analysis." zh="持续更新的实验报告与分析。" />
          </p>
        </a>
        <a class="link-card" href="https://starvla.github.io/docs/design/lego-like/" target="_blank" rel="noopener noreferrer">
          <h3 class="link-card__title">
            <BiText en="Lego-like Design" zh="Lego 式设计" />
          </h3>
          <p class="link-card__desc">
            <BiText en="Top-down modular principles for framework extension." zh="用于框架扩展的自顶向下模块化原则。" />
          </p>
        </a>
        <a class="link-card" href="https://starvla.github.io/docs/design/eval-protocol/" target="_blank" rel="noopener noreferrer">
          <h3 class="link-card__title">
            <BiText en="Evaluation Protocol" zh="评测协议" />
          </h3>
          <p class="link-card__desc">
            <BiText en="Unified policy client-server interface for deployment." zh="用于部署的一体化策略客户端-服务端接口。" />
          </p>
        </a>
      </div>

      <div class="ecosystem-grid">
        {
          landingContent.ecosystem.map((project) => (
            <a class="link-card" href={project.link} target="_blank" rel="noopener noreferrer">
              <h3 class="link-card__title">{project.name}</h3>
              <p class="link-card__desc">
                <BiText en={project.enDesc} zh={project.zhDesc} />
              </p>
            </a>
          ))
        }
      </div>
    </div>
  </section>

  <script
    is:inline
    define:vars={{
      quickStart: landingContent.quickStart,
    }}
  >
    const html = document.documentElement;
    const quickNote = document.getElementById('quickNote');
    const commandA = document.getElementById('commandA');
    const commandB = document.getElementById('commandB');
    const terminalATitle = document.getElementById('terminalATitle');
    const terminalBTitle = document.getElementById('terminalBTitle');
    const terminalBCard = document.getElementById('terminalBCard');
    const benchmarkControls = document.getElementById('benchmarkControls');

    const goalButtons = [...document.querySelectorAll('[data-goal]')];
    const benchmarkButtons = [...document.querySelectorAll('[data-benchmark]')];

    let currentGoal = 'install';
    let currentBenchmark = 'libero';

    function getLocaleText(en, zh) {
      return html.getAttribute('data-locale') === 'zh' ? zh : en;
    }

    function renderQuickStart() {
      const isZh = html.getAttribute('data-locale') === 'zh';
      const isEval = currentGoal === 'evaluate';

      benchmarkControls.hidden = !isEval;

      terminalATitle.textContent = isEval ? (isZh ? '终端 A（模型服务）' : 'Terminal A (Policy Server)') : isZh ? '终端 A' : 'Terminal A';
      terminalBTitle.textContent = isZh ? '终端 B（评测环境）' : 'Terminal B (Simulator)';

      if (!isEval) {
        const preset = quickStart.presets[currentGoal];
        commandA.textContent = preset.terminalA;
        commandB.textContent = '';
        terminalBCard.style.display = 'none';
        quickNote.textContent = getLocaleText(
          'Tip: run this in your starVLA environment and verify every command path locally.',
          '提示：请在 starVLA 环境中执行，并按本地路径校正命令。'
        );
        return;
      }

      const benchmarkMap = quickStart.presets.evaluate.mapping;
      const commands = benchmarkMap[currentBenchmark];
      commandA.textContent = commands.terminalA;
      commandB.textContent = commands.terminalB;
      terminalBCard.style.display = 'block';
      quickNote.textContent = getLocaleText(
        'Evaluation uses two terminals with separate dependencies. Keep checkpoint paths and env variables explicit.',
        '评测默认使用双终端和独立依赖环境。请显式配置 checkpoint 路径和环境变量。'
      );
    }

    goalButtons.forEach((button) => {
      button.addEventListener('click', () => {
        currentGoal = button.getAttribute('data-goal');
        goalButtons.forEach((item) => item.classList.toggle('is-active', item === button));
        renderQuickStart();
      });
    });

    benchmarkButtons.forEach((button) => {
      button.addEventListener('click', () => {
        currentBenchmark = button.getAttribute('data-benchmark');
        benchmarkButtons.forEach((item) => item.classList.toggle('is-active', item === button));
        renderQuickStart();
      });
    });

    window.addEventListener('starvla:locale', () => renderQuickStart());

    async function hydrateMetric(card) {
      const valueEl = card.querySelector('[data-metric-value]');
      const badgeUrl = card.getAttribute('data-badge-url');
      if (!valueEl || !badgeUrl) return;

      try {
        const res = await fetch(badgeUrl, { cache: 'no-store' });
        if (!res.ok) throw new Error('Request failed');
        const data = await res.json();
        valueEl.textContent = data.value || data.message || valueEl.dataset.fallback || '—';
      } catch {
        valueEl.textContent = valueEl.dataset.fallback || '—';
      }
    }

    document.querySelectorAll('[data-badge-url]').forEach((card) => hydrateMetric(card));

    document.querySelectorAll('[data-copy-target]').forEach((button) => {
      button.addEventListener('click', async () => {
        const targetId = button.getAttribute('data-copy-target');
        const target = document.getElementById(targetId);
        if (!target) return;
        try {
          await navigator.clipboard.writeText(target.textContent || '');
          const oldText = button.textContent;
          button.textContent = getLocaleText('Copied', '已复制');
          window.setTimeout(() => {
            button.textContent = oldText;
          }, 1200);
        } catch {
          button.textContent = getLocaleText('Copy failed', '复制失败');
        }
      });
    });

    renderQuickStart();

    // Video carousel: auto-rotate + dot clicks
    document.querySelectorAll('.video-carousel').forEach((carousel) => {
      const videos = [...carousel.querySelectorAll('.video-card__media')];
      const dots = [...carousel.querySelectorAll('.video-carousel__dot')];
      let current = 0;
      let timer = null;

      function switchTo(index) {
        videos[current].classList.remove('is-active');
        videos[current].pause();
        dots[current].classList.remove('is-active');

        current = index;
        const next = videos[current];
        next.classList.add('is-active');
        next.play();
        dots[current].classList.add('is-active');
      }

      function advance() {
        switchTo((current + 1) % videos.length);
      }

      function startTimer() {
        timer = setInterval(advance, 5000);
      }

      function resetTimer() {
        clearInterval(timer);
        startTimer();
      }

      dots.forEach((dot) => {
        dot.addEventListener('click', () => {
          const idx = Number(dot.dataset.index);
          if (idx !== current) {
            switchTo(idx);
            resetTimer();
          }
        });
      });

      if (videos.length > 1) startTimer();
    });
  </script>
</BaseLayout>
