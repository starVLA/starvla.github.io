---
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
}

const { title, description } = Astro.props;
const ogImage = '/assets/starvla-mark.svg';
const siteUrl = 'https://starvla.github.io/starVLA-web';
---

<!doctype html>
<html lang="en" data-theme="light" data-locale="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={siteUrl} />
    <meta property="og:image" content={`${siteUrl}${ogImage}`} />
    <meta property="og:site_name" content="starVLA" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={`${siteUrl}${ogImage}`} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="canonical" href={siteUrl} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/favicon.svg" />
    <title>{title}</title>

    <!-- JSON-LD Structured Data -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "SoftwareSourceCode",
      "name": "starVLA",
      "description": description,
      "url": siteUrl,
      "codeRepository": "https://github.com/starVLA/starVLA",
      "programmingLanguage": "Python",
      "applicationCategory": "Robotics, Embodied AI",
      "license": "https://github.com/starVLA/starVLA/blob/main/LICENSE",
      "author": {
        "@type": "Organization",
        "name": "starVLA",
        "url": "https://github.com/starVLA"
      }
    })} />

    <script is:inline>
      (() => {
        const storedTheme = localStorage.getItem('starvla-theme');
        const storedLocale = localStorage.getItem('starvla-locale');
        const theme = storedTheme || 'system';
        const locale =
          storedLocale || ((navigator.language || '').toLowerCase().startsWith('zh') ? 'zh' : 'en');
        const resolvedTheme =
          theme === 'system'
            ? (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light')
            : theme;

        document.documentElement.setAttribute('data-theme', resolvedTheme);
        document.documentElement.setAttribute('data-locale', locale);
        document.documentElement.setAttribute('lang', locale === 'zh' ? 'zh-CN' : 'en');
      })();
    </script>
  </head>
  <body>
    <slot />
  </body>
</html>
