---
import '../styles/global.css';
import BiText from '../components/BiText.astro';
import { landingContent } from '../data/landingContent';

interface Props {
  title: string;
  description: string;
}

const { title, description } = Astro.props;
const ogImage = '/assets/starvla-mark.svg';
const siteUrl = 'https://starvla.github.io/starVLA-web';
---

<!doctype html>
<html lang="en" data-theme="light" data-locale="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={siteUrl} />
    <meta property="og:image" content={`${siteUrl}${ogImage}`} />
    <meta property="og:site_name" content="starVLA" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={`${siteUrl}${ogImage}`} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="canonical" href={siteUrl} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/favicon.svg" />
    <title>{title}</title>

    <!-- JSON-LD Structured Data -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "SoftwareSourceCode",
      "name": "starVLA",
      "description": description,
      "url": siteUrl,
      "codeRepository": "https://github.com/starVLA/starVLA",
      "programmingLanguage": "Python",
      "applicationCategory": "Robotics, Embodied AI",
      "license": "https://github.com/starVLA/starVLA/blob/main/LICENSE",
      "author": {
        "@type": "Organization",
        "name": "starVLA",
        "url": "https://github.com/starVLA"
      }
    })} />

    <script is:inline>
      (() => {
        const storedTheme = localStorage.getItem('starvla-theme');
        const storedLocale = localStorage.getItem('starvla-locale');
        const theme = storedTheme || 'system';
        const locale =
          storedLocale || ((navigator.language || '').toLowerCase().startsWith('zh') ? 'zh' : 'en');
        const resolvedTheme =
          theme === 'system'
            ? (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light')
            : theme;

        document.documentElement.setAttribute('data-theme', resolvedTheme);
        document.documentElement.setAttribute('data-locale', locale);
        document.documentElement.setAttribute('lang', locale === 'zh' ? 'zh-CN' : 'en');
      })();
    </script>
  </head>
  <body>
    <div class="page-shell">
      <a class="skip-link" href="#main-content">Skip to main content</a>
      <header class="top-nav">
        <div class="container top-nav__inner">
          <a class="brand" href="/">
            <span class="brand__star" aria-hidden="true">
              <img src="/assets/starvla-mark.svg" alt="" />
            </span>
            <span>starVLA</span>
          </a>

          <nav class="nav-links" aria-label="Primary">
            {
              landingContent.nav.map((item) => (
                <a class="nav-link" href={`/#${item.id}`}>
                  <BiText en={item.en} zh={item.zh} />
                </a>
              ))
            }
            <a class="nav-link" href="/contributors">
              <BiText en="Contributors" zh="贡献者" />
            </a>
          </nav>

          <div class="nav-actions">
            <a class="action-btn" href={landingContent.community.github} target="_blank" rel="noopener noreferrer">
              GitHub
            </a>
            <button id="localeToggle" class="action-btn" aria-label="Toggle language">
              <span data-locale-content="en">中文</span>
              <span data-locale-content="zh">EN</span>
            </button>
            <button id="themeToggle" class="action-btn" aria-label="Toggle theme">
              <span id="themeToggleText">Theme</span>
            </button>
          </div>
        </div>
      </header>

      <main id="main-content">
        <slot />
      </main>

      <footer class="footer">
        <div class="container footer-row">
          <div>
            <BiText en="© 2026 starVLA. All rights reserved." zh="© 2026 starVLA。保留所有权利。" />
          </div>
          <div class="footer-links">
            <a href={landingContent.community.github} target="_blank" rel="noopener noreferrer">GitHub</a>
            <a href={landingContent.community.docs} target="_blank" rel="noopener noreferrer">Docs</a>
            <a href={landingContent.community.huggingFace} target="_blank" rel="noopener noreferrer">Hugging Face</a>
          </div>
        </div>
      </footer>
    </div>

    <script is:inline>
      (() => {
        const html = document.documentElement;
        const localeToggle = document.getElementById('localeToggle');
        const themeToggle = document.getElementById('themeToggle');
        const themeToggleText = document.getElementById('themeToggleText');

        let currentThemePref = localStorage.getItem('starvla-theme') || 'system';

        function resolveTheme(themePref) {
          if (themePref === 'system') {
            return window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
          }
          return themePref;
        }

        function renderThemeLabel() {
          const activeTheme = html.getAttribute('data-theme');
          const locale = html.getAttribute('data-locale');
          const map = {
            en: activeTheme === 'dark' ? 'Dark' : 'Light',
            zh: activeTheme === 'dark' ? '深色' : '浅色',
          };
          themeToggleText.textContent = map[locale] || map.en;
        }

        function setLocale(locale) {
          html.setAttribute('data-locale', locale);
          html.setAttribute('lang', locale === 'zh' ? 'zh-CN' : 'en');
          localStorage.setItem('starvla-locale', locale);
          renderThemeLabel();
          window.dispatchEvent(new CustomEvent('starvla:locale', { detail: locale }));
        }

        function setThemePreference(themePref) {
          currentThemePref = themePref;
          localStorage.setItem('starvla-theme', themePref);
          html.setAttribute('data-theme', resolveTheme(themePref));
          renderThemeLabel();
        }

        localeToggle.addEventListener('click', () => {
          const cur = html.getAttribute('data-locale') || 'en';
          setLocale(cur === 'en' ? 'zh' : 'en');
        });

        themeToggle.addEventListener('click', () => {
          const next = resolveTheme(currentThemePref) === 'dark' ? 'light' : 'dark';
          setThemePreference(next);
        });

        window.matchMedia('(prefers-color-scheme: dark)').addEventListener('change', () => {
          if (currentThemePref === 'system') {
            html.setAttribute('data-theme', resolveTheme('system'));
            renderThemeLabel();
          }
        });

        const revealNodes = [...document.querySelectorAll('.reveal')];
        const revealObserver = new IntersectionObserver(
          (entries, obs) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                entry.target.classList.add('is-visible');
                obs.unobserve(entry.target);
              }
            });
          },
          { threshold: 0.16 }
        );
        revealNodes.forEach((node) => revealObserver.observe(node));

        setLocale(html.getAttribute('data-locale') || 'en');
        setThemePreference(currentThemePref);
      })();
    </script>
  </body>
</html>
