---
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
}

const { title, description } = Astro.props;
---

<!doctype html>
<html lang="en" data-theme="light" data-locale="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/favicon.svg" />
    <title>{title}</title>
    <script is:inline>
      (() => {
        const storedTheme = localStorage.getItem('starvla-theme');
        const storedLocale = localStorage.getItem('starvla-locale');
        const theme = storedTheme || 'system';
        const locale =
          storedLocale || ((navigator.language || '').toLowerCase().startsWith('zh') ? 'zh' : 'en');
        const resolvedTheme =
          theme === 'system'
            ? (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light')
            : theme;

        document.documentElement.setAttribute('data-theme', resolvedTheme);
        document.documentElement.setAttribute('data-locale', locale);
      })();
    </script>
  </head>
  <body>
    <slot />
  </body>
</html>
